{
  "manifest_version": 3,
  "name": "AskIt - AI Assistant",
  "version": "4.0.0",
  "description": "MaxAI-style AI Assistant: Chat, Summarize, Translate, Image, TTS, Music",
  "permissions": ["activeTab", "storage", "tabs", "contextMenus", "scripting"],
  "host_permissions": [
    "https://api.minimaxi.com/*",
    "https://api.minimax.io/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+J" },
      "description": "Toggle AskIt Sidebar"
    }
  }
}
